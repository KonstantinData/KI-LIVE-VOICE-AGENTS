# ═══════════════════════════════════════
# Server
# ═══════════════════════════════════════
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=DEBUG

# ═══════════════════════════════════════
# Datenbank
# ═══════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://ki_team:PASSWORT@localhost:5432/ki_mitarbeiter

# ═══════════════════════════════════════
# Anthropic Claude (Agent-Gehirn)
# ═══════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# ═══════════════════════════════════════
# OpenAI (Embeddings)
# ═══════════════════════════════════════
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ═══════════════════════════════════════
# OpenAI Realtime (Live Voice Agents)
# ═══════════════════════════════════════
ENABLE_VOICE_SESSIONS=false
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
MAX_VOICE_SESSION_SECONDS=900
MAX_VOICE_SDP_CHARS=200000

# ═══════════════════════════════════════
# Resend (E-Mail)
# ═══════════════════════════════════════
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=lisa@mein-kuechenexperte.de
RESEND_FROM_NAME=KEA | Mein Küchenexperte
ENABLE_EMAIL_SENDING=false

# ═══════════════════════════════════════
# Google Calendar OAuth
# ═══════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.mein-kuechenexperte.de/auth/google/callback
ENABLE_CALENDAR_SYNC=false

# ═══════════════════════════════════════
# Auth (Dashboard)
# ═══════════════════════════════════════
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
ADMIN_STUDIO_SLUG=mein-kuechenexperte
ALLOW_DEMO_LOGIN=false
JWT_SECRET=HIER-MINDESTENS-32-ZEICHEN-ZUFAELLIGER-STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ═══════════════════════════════════════
# Encryption (Calendar Tokens etc.)
# ═══════════════════════════════════════
ENCRYPTION_KEY=HIER-64-ZEICHEN-HEX-STRING

# ═══════════════════════════════════════
# URLs
# ═══════════════════════════════════════
API_URL=https://api.mein-kuechenexperte.de
WS_URL=wss://api.mein-kuechenexperte.de
DASHBOARD_URL=https://app.mein-kuechenexperte.de
WIDGET_URL=https://widget.mein-kuechenexperte.de
WEBSITE_URL=https://www.mein-kuechenexperte.de

# ═══════════════════════════════════════
# CORS
# ═══════════════════════════════════════
CORS_ORIGINS=["https://www.mein-kuechenexperte.de","https://mein-kuechenexperte.de","https://app.mein-kuechenexperte.de"]

# ═══════════════════════════════════════
# Runtime Limits
# ═══════════════════════════════════════
MAX_CHAT_MESSAGE_CHARS=4000

# ═══════════════════════════════════════
# Private Project Uploads
# ═══════════════════════════════════════
UPLOAD_STORAGE_DIR=/var/lib/ki-team/uploads
MAX_UPLOAD_FILE_BYTES=10485760
MAX_UPLOAD_FILES_PER_SELECTION=10
MAX_UPLOADS_PER_VISITOR_HOUR=10
MAX_UPLOADS_PER_CONVERSATION=30
ENABLE_UPLOAD_AI_ANALYSIS=true
