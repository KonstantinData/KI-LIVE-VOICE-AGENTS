# Local text provider
LIQUISTO_ASSISTANT_SERVICE_TOKEN=replace-with-a-long-random-service-token
LIQUISTO_ASSISTANT_LLM_MODEL=replace-with-the-approved-local-model

# Internal Olivia Voice is fail-closed by default. Enable only after the SCAS
# employee-authenticated BFF is deployed. The OpenAI key remains server-side.
LIQUISTO_ASSISTANT_VOICE_ENABLED=false
OPENAI_API_KEY=
